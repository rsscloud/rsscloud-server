<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>rssCloud v2 - Stats</title>
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <h1>rssCloud v2 - Stats</h1>

    <h2>Overview</h2>
    <table class="stats-table">
        <tr>
            <td>Feeds changed in last 7 days</td>
            <td>{{feedsChangedLast7Days}}</td>
        </tr>
        <tr>
            <td>Feeds with subscribers</td>
            <td>{{feedsWithSubscribers}}</td>
        </tr>
        <tr>
            <td>Unique aggregators</td>
            <td>{{uniqueAggregators}}</td>
        </tr>
        <tr>
            <td>Total active subscriptions</td>
            <td>{{totalActiveSubscriptions}}</td>
        </tr>
    </table>

    <h2>Protocol Breakdown</h2>
    <table class="stats-table">
        <tr>
            <th>Protocol</th>
            <th>Count</th>
        </tr>
        <tr>
            <td>http-post</td>
            <td>{{protocolBreakdown.http-post}}</td>
        </tr>
        <tr>
            <td>https-post</td>
            <td>{{protocolBreakdown.https-post}}</td>
        </tr>
        <tr>
            <td>xml-rpc</td>
            <td>{{protocolBreakdown.xml-rpc}}</td>
        </tr>
    </table>

    {{#if topFeeds.length}}
    <h2>Top Most Subscribed Feeds</h2>
    <table class="stats-table">
        <tr>
            <th>Feed URL</th>
            <th>Subscribers</th>
        </tr>
        {{#each topFeeds}}
        <tr>
            <td>
                {{this.url}}
                {{#if this.whenLastUpdate}}
                <br><small class="feed-last-update">Last updated: <time datetime="{{this.whenLastUpdate}}">{{this.whenLastUpdate}}</time></small>
                {{/if}}
            </td>
            <td>{{this.subscriberCount}}</td>
        </tr>
        {{/each}}
        {{#each moreFeeds}}
        <tr class="more-feed-row" hidden>
            <td>
                {{this.url}}
                {{#if this.whenLastUpdate}}
                <br><small class="feed-last-update">Last updated: <time datetime="{{this.whenLastUpdate}}">{{this.whenLastUpdate}}</time></small>
                {{/if}}
            </td>
            <td>{{this.subscriberCount}}</td>
        </tr>
        {{/each}}
        {{#if moreFeeds.length}}
        <tr class="toggle-row">
            <td colspan="2">
                <a href="#" id="toggle-all-feeds" role="button" aria-expanded="false">Show All &#x25BC;</a>
            </td>
        </tr>
        {{/if}}
    </table>
    {{/if}}

    <p>Generated at: <time datetime="{{generatedAt}}" id="generated-at">{{generatedAt}}</time></p>

    <script>
    (function () {
        var el = document.getElementById('generated-at');
        if (!el) return;
        var d = new Date(el.getAttribute('datetime'));
        if (isNaN(d.getTime())) return;
        el.textContent = d.toLocaleString(undefined, { dateStyle: 'long', timeStyle: 'long' });
    })();
    (function () {
        var els = document.querySelectorAll('.feed-last-update time');
        if (!els.length) return;
        els.forEach(function (el) {
            var d = new Date(el.getAttribute('datetime'));
            if (isNaN(d.getTime())) return;
            el.textContent = d.toLocaleString(undefined, { dateStyle: 'long', timeStyle: 'long' });
        });
    })();
    (function () {
        var btn = document.getElementById('toggle-all-feeds');
        if (!btn) return;
        var rows = document.querySelectorAll('.more-feed-row');
        if (!rows.length) return;
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            var expanded = btn.getAttribute('aria-expanded') === 'true';
            var next = !expanded;
            rows.forEach(function (r) { r.hidden = !next; });
            btn.setAttribute('aria-expanded', next ? 'true' : 'false');
            btn.textContent = next ? 'Show Less ▲' : 'Show All ▼';
        });
    })();
    </script>
    <p><a href="/stats.json">View Stats as JSON</a> | <a href="/subscriptions.json">View Raw Data as JSON</a> | <a href="/">Home</a></p>
</body>
</html>
